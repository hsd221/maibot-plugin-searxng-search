  "author": {
    "name": "hsd221",
    "url": "https://github.com/hsd221"
  },
  "license": "GPL-3.0-or-later",
  "repository_url": "https://github.com/hsd221/maibot-plugin-searxng-search",
  "homepage_url": "https://github.com/hsd221/maibot-plugin-searxng-search",
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": ["llm.generate"],
  "i18n": {
    "default_locale": "zh-CN",
